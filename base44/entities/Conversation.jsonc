{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string",
      "description": "The user this conversation belongs to"
    },
    "user_name": {
      "type": "string",
      "description": "Display name of the user"
    },
    "last_message": {
      "type": "string",
      "description": "Preview of last message"
    },
    "last_message_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_sender": {
      "type": "string",
      "enum": [
        "admin",
        "user"
      ],
      "description": "Who sent the last message"
    },
    "unread_by_admin": {
      "type": "number",
      "default": 0
    },
    "unread_by_user": {
      "type": "number",
      "default": 0
    },
    "is_archived": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "user_email"
  ],
  "rls": {
    "create": {},
    "read": {
      "$or": [
        {
          "data.user_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.user_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}